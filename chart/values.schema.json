{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "multicast-relay values",
  "type": "object",
  "properties": {
    "nameOverride": {
      "type": "string"
    },
    "fullnameOverride": {
      "type": "string"
    },
    "namespaceOverride": {
      "type": "string"
    },
    "replicaCount": {
      "type": "integer",
      "minimum": 0
    },
    "strategy": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["Recreate", "RollingUpdate"]
        }
      },
      "required": ["type"],
      "additionalProperties": false
    },
    "image": {
      "type": "object",
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "tag": {
          "type": "string"
        },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        }
      },
      "required": ["repository", "pullPolicy"],
      "additionalProperties": false
    },
    "relay": {
      "type": "object",
      "properties": {
        "interfaces": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "noTransmitInterfaces": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "remote": {
          "type": "object",
          "properties": {
            "addresses": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "port": {
              "type": ["integer", "null"],
              "minimum": 1,
              "maximum": 65535
            }
          },
          "required": ["addresses", "port"],
          "additionalProperties": false,
          "allOf": [
            {
              "if": {
                "properties": {
                  "addresses": {
                    "minItems": 1
                  }
                },
                "required": ["addresses"]
              },
              "then": {
                "properties": {
                  "port": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 65535
                  }
                }
              }
            }
          ]
        },
        "wait": {
          "type": "boolean"
        },
        "transmitUdp": {
          "type": "boolean"
        },
        "noRemoteRelay": {
          "type": "boolean"
        },
        "verbose": {
          "type": "boolean"
        },
        "debug": {
          "type": "boolean"
        },
        "extraArgs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "interfaces",
        "noTransmitInterfaces",
        "remote",
        "wait",
        "transmitUdp",
        "noRemoteRelay",
        "verbose",
        "debug",
        "extraArgs"
      ],
      "additionalProperties": false
    },
    "livenessPort": {
      "type": "integer",
      "minimum": 1,
      "maximum": 65535
    },
    "metrics": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "podMonitor": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "namespace": {
              "type": "string"
            },
            "labels": {
              "$ref": "#/definitions/stringMap"
            },
            "interval": {
              "type": "string",
              "minLength": 1
            },
            "scrapeTimeout": {
              "type": "string"
            },
            "path": {
              "type": "string",
              "pattern": "^/"
            }
          },
          "required": ["enabled", "namespace", "labels", "interval", "scrapeTimeout", "path"],
          "additionalProperties": false
        }
      },
      "required": ["enabled", "port", "podMonitor"],
      "additionalProperties": false
    },
    "env": {
      "type": "object",
      "additionalProperties": {
        "type": ["string", "number", "boolean"]
      }
    },
    "extraEnv": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "hostNetwork": {
      "type": "boolean"
    },
    "dnsPolicy": {
      "type": "string",
      "enum": ["ClusterFirst", "ClusterFirstWithHostNet", "Default", "None"]
    },
    "terminationGracePeriodSeconds": {
      "type": "integer",
      "minimum": 0
    },
    "podAnnotations": {
      "$ref": "#/definitions/stringMap"
    },
    "podLabels": {
      "$ref": "#/definitions/stringMap"
    },
    "containerSecurityContext": {
      "type": "object"
    },
    "resources": {
      "type": "object"
    },
    "probes": {
      "type": "object",
      "properties": {
        "liveness": {
          "$ref": "#/definitions/probe"
        },
        "readiness": {
          "$ref": "#/definitions/probe"
        }
      },
      "required": ["liveness", "readiness"],
      "additionalProperties": false
    },
    "nodeSelector": {
      "$ref": "#/definitions/stringMap"
    },
    "tolerations": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "affinity": {
      "type": "object"
    },
    "networkPolicy": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "flavor": {
          "type": "string",
          "enum": ["kubernetes", "cilium"]
        },
        "policyTypes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["Ingress", "Egress"]
          },
          "uniqueItems": true
        },
        "ingress": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "egress": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "cilium": {
          "type": "object",
          "properties": {
            "ingress": {
              "type": "array",
              "items": {
                "type": "object"
              }
            },
            "egress": {
              "type": "array",
              "items": {
                "type": "object"
              }
            },
            "enableDefaultDeny": {
              "type": "object"
            }
          },
          "required": ["ingress", "egress", "enableDefaultDeny"],
          "additionalProperties": false
        }
      },
      "required": ["enabled", "flavor", "policyTypes", "ingress", "egress", "cilium"],
      "additionalProperties": false
    }
  },
  "required": ["image", "relay", "livenessPort", "metrics"],
  "allOf": [
    {
      "if": {
        "properties": {
          "metrics": {
            "properties": {
              "podMonitor": {
                "properties": {
                  "enabled": {
                    "const": true
                  }
                },
                "required": ["enabled"]
              }
            },
            "required": ["podMonitor"]
          }
        },
        "required": ["metrics"]
      },
      "then": {
        "properties": {
          "metrics": {
            "properties": {
              "enabled": {
                "const": true
              }
            },
            "required": ["enabled"]
          }
        }
      }
    }
  ],
  "definitions": {
    "stringMap": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "probe": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "path": {
          "type": "string",
          "pattern": "^/"
        },
        "initialDelaySeconds": {
          "type": "integer",
          "minimum": 0
        },
        "periodSeconds": {
          "type": "integer",
          "minimum": 1
        },
        "timeoutSeconds": {
          "type": "integer",
          "minimum": 1
        },
        "successThreshold": {
          "type": "integer",
          "minimum": 1
        },
        "failureThreshold": {
          "type": "integer",
          "minimum": 1
        }
      },
      "required": [
        "enabled",
        "path",
        "initialDelaySeconds",
        "periodSeconds",
        "timeoutSeconds",
        "successThreshold",
        "failureThreshold"
      ],
      "additionalProperties": false
    }
  }
}
